generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TREASURER
  MEMBER
}

enum LoanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(MEMBER)
  status        String         @default("ACTIVE")
  createdBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Notifications Notification[]
}

model Group {
  id             String   @id @default(uuid())
  groupName      String
  description    String?
  location       String
  cycleStartDate DateTime
  cycleEndDate   DateTime
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  Members        Member[]
}

model Member {
  id               String     @id @default(uuid())
  groupId          String
  Group            Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fullName         String
  phoneNumber      String
  email            String?
  gender           String
  address          String?
  membershipStatus String     @default("ACTIVE")
  joinedDate       DateTime   @default(now())
  createdAt        DateTime   @default(now())
  Savings          Saving[]
  Loans            Loan[]
  ShareOuts        ShareOut[]
}

model Saving {
  id         String   @id @default(uuid())
  memberId   String
  Member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount     Float
  savingDate DateTime @default(now())
  recordedBy String
}

model Loan {
  id           String      @id @default(uuid())
  memberId     String
  Member       Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount       Float
  interestRate Float
  loanDate     DateTime    @default(now())
  dueDate      DateTime
  status       LoanStatus  @default(ACTIVE)
  Repayments   Repayment[]
}

model Repayment {
  id               String   @id @default(uuid())
  loanId           String
  Loan             Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amountPaid       Float
  paymentDate      DateTime @default(now())
  remainingBalance Float
}

model ShareOut {
  id           String @id @default(uuid())
  memberId     String
  Member       Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  cycleId      String
  totalSavings Float
  shareAmount  Float
}

model Transaction {
  id          String   @id @default(uuid())
  type        String // e.g., "SAVING", "LOAN_ISSUED", "REPAYMENT", "SHARE_OUT"
  amount      Float
  description String
  createdBy   String // ID of User who recorded it
  createdAt   DateTime @default(now())
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message    String
  readStatus Boolean  @default(false)
  createdAt  DateTime @default(now())
}
