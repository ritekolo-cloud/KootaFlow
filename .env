build for me a backend and a fronted for an app called "KootaFlow" with this as an env file

 # Server
DATABASE_URL="postgresql://postgres:admin@localhost:5432/kootaflow
NODE_ENV=development
PORT=5000

# JWT
JWT_SECRET=kootaflow_jwt_super_secret_key_2024_change_in_production
JWT_REFRESH_SECRET=kootaflow_refresh_super_secret_key_2024_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client origin
CLIENT_URL=http://localhost:5173

# DB
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Branham7
DB_NAME=kootaflow

# Email Gateway (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
# Note: For production Gmail, use an App Password, not your regular password.